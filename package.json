{
  "name": "tokenbar-core",
  "version": "0.0.1",
  "description": "TypeScript data collector layer for TokenBar — local-first AI token usage tracking",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "dev:listener": "tsx src/cli.ts listen",
    "dev:sync-fixture": "tsx src/cli.ts sync-fixture",
    "dev:replay-fixture": "tsx src/cli.ts replay-fixture",
    "lint": "eslint src/ tests/",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "tokenbar",
    "ai",
    "tokens",
    "usage",
    "opentelemetry",
    "sqlite"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.32.0",
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  }
}
